# ====== AI provider selection ======
# "gemini" (default, for Vercel production)  |  "claude" (for local dev with your Anthropic key)
AI_PROVIDER=gemini

# ====== Provider credentials (fill in the one that matches AI_PROVIDER) ======

# Gemini — create at https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=

# Anthropic Claude — create at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
