# ====== AI provider selection ======
# "gemini" (default, for Vercel production)  |  "claude" (for local dev with your Anthropic key)
AI_PROVIDER=gemini

# ====== Provider credentials (fill in the one that matches AI_PROVIDER) ======

# Gemini — create at https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=

# Anthropic Claude — create at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# ====== Supabase (auth + per-user storage) ======
# Browser-side credentials.  Both are safe to ship in client bundles.
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql once in Supabase SQL Editor
# 3. Find these values at:  Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side: /api/translate verifies the caller's JWT against Supabase's
# /auth/v1/user endpoint to keep anonymous traffic from burning the AI
# quota.  These can be the same values as VITE_SUPABASE_URL /
# VITE_SUPABASE_PUBLISHABLE_KEY above — the function reads either form,
# so you only need to add them again if you'd rather keep server vars
# separate from client vars in Vercel.
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
